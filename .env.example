# Frontend (Vite) - Firebase config (client-side)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend (Node/Express) - Gemini (server-side)
GEMINI_API_KEY=

# Frontend (Vite) - Optional: external API base for AI endpoints (Cloudflare Worker, etc.)
# Example: https://your-worker.your-subdomain.workers.dev
VITE_API_BASE_URL=

# Frontend (Vite) - Owner/admin email (only this account sees admin user count panel)
VITE_OWNER_EMAIL=

